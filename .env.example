# Database
DATABASE_URL=postgresql+asyncpg://complaintiq:complaintiq@localhost:5432/complaintiq
DATABASE_URL_SYNC=postgresql://complaintiq:complaintiq@localhost:5432/complaintiq

# Google Gemini — paste your key here
GEMINI_API_KEY=your-gemini-api-key-here

# JWT
JWT_SECRET=change-me-in-production

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend API URL configuration
VITE_API_URL=http://localhost:8000

# Email Configuration
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=your-imap-email@gmail.com
IMAP_PASSWORD=your-imap-password-here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-smtp-email@gmail.com
SMTP_PASSWORD=your-smtp-password-here

# AI Models
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
