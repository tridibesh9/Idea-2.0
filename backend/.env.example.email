# Email Configuration for ComplaintIQ
# Copy this to your .env file and update with your actual credentials

# ── IMAP Configuration (for receiving emails) ──
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=support@yourdomain.com
IMAP_PASSWORD=your_app_password_here

# ── SMTP Configuration (for sending replies) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=support@yourdomain.com
SMTP_PASSWORD=your_app_password_here

# ── Support Email Configuration ──
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_NAME=ComplaintIQ Support

# ── Email Listener Settings ──
EMAIL_LISTENER_ENABLED=false
EMAIL_CHECK_INTERVAL=60

# ──────────────────────────────────────────────────────
# SETUP INSTRUCTIONS
# ──────────────────────────────────────────────────────

# 1. Gmail Setup (if using Gmail):
#    - Enable 2-Factor Authentication
#    - Generate an App Password: https://support.google.com/accounts/answer/185833
#    - Use the generated password for IMAP_PASSWORD and SMTP_PASSWORD
#    - You may need to allow "Less secure app access" depending on your Gmail settings

# 2. Other Email Providers:
#    - Gmail: IMAP: imap.gmail.com:993, SMTP: smtp.gmail.com:587
#    - Outlook: IMAP: outlook.office365.com:993, SMTP: outlook.office365.com:587
#    - Yahoo: IMAP: imap.mail.yahoo.com:993, SMTP: smtp.mail.yahoo.com:587
#    - Custom Domain: Contact your email provider for IMAP/SMTP settings

# 3. To Enable Email Listener:
#    - Set EMAIL_LISTENER_ENABLED=true
#    - Configure IMAP credentials
#    - Restart the application
#    - The listener will check for new emails every EMAIL_CHECK_INTERVAL seconds
